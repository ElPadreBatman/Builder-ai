"use client"

import { useEffect, useRef } from "react"

/**
 * AnimatedDashboardBackground - Fond animé light pour dashboard BuilderAI
 * 
 * Inspiré du style landing page avec:
 * - Icônes de construction flottantes subtiles
 * - Orbes douces orange/ambre (couleur brand)
 * - Grille technique légère
 * - Particules lumineuses
 * 
 * Usage: Placer comme premier enfant du conteneur principal
 * <div className="min-h-screen relative">
 *   <AnimatedDashboardBackground />
 *   {/* Contenu */}
 * </div>
 */

const CONSTRUCTION_ICONS = [
  // Règle/mesure
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M2 12h20M2 12l4-4m-4 4l4 4M22 12l-4-4m4 4l-4 4"/>
    <path d="M7 10v4M12 8v8M17 10v4"/>
