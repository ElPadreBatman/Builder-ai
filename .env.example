# ─── Estimateur IA — Gestion A.F. Construction ───────────────────────────────

# Clé API Anthropic (claude-sonnet-4-6)
# Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# URL du webhook n8n pour router le lead → Zoho CRM + Jade SMS
# Laisser vide pour activer le mode démo (payload loggé dans la console)
N8N_WEBHOOK_URL=https://votre-instance-n8n.com/webhook/XXXX

# Lien de réservation Microsoft Bookings (affiché sur le bouton final)
# Accessible côté client — doit avoir le préfixe NEXT_PUBLIC_
NEXT_PUBLIC_BOOKING_URL=https://outlook.office365.com/owa/calendar/...

# Domaine(s) réservés à l'estimateur client (séparés par virgule si plusieurs)
# Le middleware bloque toutes les routes Builder AI sur ce domaine et redirige vers /estimateur
# Exemple : estimer.gestionnaf.ca
# Laisser vide = pas de restriction (les deux apps coexistent sur le même domaine)
CUSTOMER_DOMAIN=estimer.gestionnaf.ca

# ─── App principale Builder AI ───────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OpenAI (utilisé par les autres modules)
OPENAI_API_KEY=

# Resend (email)
RESEND_API_KEY=
